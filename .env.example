# Copy this file to .env.local and fill in your own values.

# Anthropic API key — get one from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase service account (Firestore) — used for access requests + feedback.
# Get these from Firebase Console > Project Settings > Service Accounts >
# "Generate new private key" (downloads a JSON file with these three values).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxxxxxxxxxxx\n-----END PRIVATE KEY-----\n"

# Password you'll use to log into the admin screen (choose your own).
ADMIN_PASSWORD=choose-a-strong-password
